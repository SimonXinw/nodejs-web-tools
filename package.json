{
  "name": "nodejs-web-tools",
  "version": "1.0.0",
  "description": "基于 Node.js 和 Playwright 的金价爬虫工具",
  "main": "main.js",
  "bin": {
    "gold-scraper": "./main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node -r dotenv/config src/index.ts",
    "dev:gold": "ts-node -r dotenv/config src/index.ts --scraper gold-price",
    "dev:gold:manual": "ts-node -r dotenv/config src/index.ts --scraper gold-price --manual",
    "dev:efunds": "ts-node -r dotenv/config src/index.ts --scraper efunds-dividend",
    "dev:efunds:manual": "ts-node -r dotenv/config src/index.ts --scraper efunds-dividend --manual",
    "dev:api": "ts-node -r dotenv/config src/index.ts --api",
    "start": "node -r dotenv/config dist/index.js",
    "start:gold": "node -r dotenv/config dist/index.js --scraper gold-price",
    "start:gold:manual": "node -r dotenv/config dist/index.js --scraper gold-price --manual",
    "start:efunds": "node -r dotenv/config dist/index.js --scraper efunds-dividend",
    "start:efunds:manual": "node -r dotenv/config dist/index.js --scraper efunds-dividend --manual",
    "start:api": "node -r dotenv/config dist/index.js --api",
    "setup": "node scripts/setup.mjs",
    "download:efunds": "ts-node -r dotenv/config scripts/efunds/downloadLatestExcel.ts",
    "import:efunds": "ts-node -r dotenv/config scripts/efunds/initFormateExcelToDatabase.ts",
    "sync:efunds": "ts-node -r dotenv/config scripts/efunds/downloadLatestExcel.ts && ts-node -r dotenv/config scripts/efunds/initFormateExcelToDatabase.ts",
    "clean": "rimraf dist logs/*.log",
    "pm2:start": "pnpm build && pm2 start ecosystem.config.js",
    "pm2:start:gold": "pnpm build && pm2 startOrReload ecosystem.config.js --only gold-scraper",
    "pm2:start:efunds": "pnpm build && pm2 startOrReload ecosystem.config.js --only efunds-scraper",
    "pm2:stop": "pm2 stop all",
    "pm2:stop:gold": "pm2 stop gold-scraper",
    "pm2:stop:efunds": "pm2 stop efunds-scraper",
    "pm2:restart": "pm2 reload ecosystem.config.js",
    "pm2:restart:gold": "pm2 reload ecosystem.config.js --only gold-scraper",
    "pm2:restart:efunds": "pm2 reload ecosystem.config.js --only efunds-scraper",
    "pm2:delete": "pm2 delete all",
    "pm2:logs": "pm2 logs",
    "pm2:logs:gold": "pm2 logs gold-scraper",
    "pm2:logs:efunds": "pm2 logs efunds-scraper",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit",
    "deploy": "git pull && pnpm install --frozen-lockfile && pnpm build && pm2 reload ecosystem.config.js",
    "deploy:gold": "git pull && pnpm install --frozen-lockfile && pnpm build && pm2 reload ecosystem.config.js --only gold-scraper",
    "deploy:efunds": "git pull && pnpm install --frozen-lockfile && pnpm build && pm2 reload ecosystem.config.js --only efunds-scraper",
    "efunds:start": "bash scripts/efunds/deploy/start-efunds.sh",
    "efunds:setup": "bash scripts/efunds/deploy/start-efunds.sh --setup",
    "docker:build": "docker build -t gold-scraper .",
    "docker:run": "docker run -d --name gold-scraper --env-file .env -p 3667:3667 -v $(pwd)/logs:/app/logs gold-scraper",
    "docker:stop": "docker stop gold-scraper",
    "docker:remove": "docker rm gold-scraper",
    "docker:logs": "docker logs -f gold-scraper",
    "compose:up": "docker-compose up -d",
    "compose:down": "docker-compose down",
    "compose:logs": "docker-compose logs -f"
  },
  "keywords": [
    "scraper",
    "playwright",
    "supabase",
    "gold-price",
    "crawler"
  ],
  "author": "Simon",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "playwright": "^1.40.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.0",
    "@types/node-cron": "^3.0.8",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
